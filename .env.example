# Production (à définir aussi dans Vercel → Environment Variables)
NEXT_PUBLIC_SITE_URL=https://manchoufouch.ma

# Local
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# IA gratuite — Google Gemini
# Clé : https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# Scores Google PageSpeed (gratuit)
# https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
PAGESPEED_API_KEY=

# Indexation IndexNow (optionnel)
# INDEXNOW_KEY=manchoufouch-indexnow-7f3a9c2e1b84

# Option payante (optionnel)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Session auth (cookie signé) — changez en production
# AUTH_SECRET=une-chaine-longue-et-aleatoire

# Stockage durable des comptes (Vercel Blob) — requis en production
# Créé automatiquement via `vercel blob` / dashboard Storage
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=

# Google reCAPTCHA v2 (case « Je ne suis pas un robot »)
# Créer les clés : https://www.google.com/recaptcha/admin
# Domaines : manchoufouch.ma + localhost
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
